#!/usr/bin/env python3

import json
import os
import shlex
import socket
import subprocess
import sys
import time
from pathlib import Path


WORKSPACE_EVENTS = {"workspacev2"}
AGS_INSTANCE = "workspace-info-osd"
AGS_QUIT_COMMAND = [
    "ags",
    "quit",
    "--instance",
    AGS_INSTANCE,
]
AGS_COMMAND = [
    "ags",
    "run",
    os.path.expanduser("~/.config/ags/window/onscreen-display/workspace-info.tsx"),
    "--gtk",
    "4",
]


def fail(message: str, exit_code: int = 1) -> "None":
    print(message, file=sys.stderr)
    raise SystemExit(exit_code)


def resolve_runtime_dir() -> Path:
    runtime_dir = os.environ.get("XDG_RUNTIME_DIR")
    if not runtime_dir:
        fail("XDG_RUNTIME_DIR is not set")

    path = Path(runtime_dir)
    if not path.exists():
        fail(f"Runtime directory does not exist: {path}")

    return path


def resolve_instance_dir(runtime_dir: Path) -> Path:
    hypr_root = runtime_dir / "hypr"
    if not hypr_root.is_dir():
        fail(f"Hyprland runtime directory not found: {hypr_root}")

    instance = os.environ.get("HYPRLAND_INSTANCE_SIGNATURE")
    if instance:
        instance_dir = hypr_root / instance
        if not instance_dir.is_dir():
            fail(f"Hyprland instance not found: {instance_dir}")
        return instance_dir

    candidates = sorted(path for path in hypr_root.iterdir() if path.is_dir())
    if not candidates:
        fail(f"No Hyprland instances found under {hypr_root}")
    if len(candidates) > 1:
        joined = ", ".join(path.name for path in candidates)
        fail(
            "Multiple Hyprland instances found. Set HYPRLAND_INSTANCE_SIGNATURE. "
            f"Available: {joined}"
        )

    return candidates[0]


def event_socket_path(instance_dir: Path) -> Path:
    return instance_dir / ".socket2.sock"


def request_socket_path(instance_dir: Path) -> Path:
    return instance_dir / ".socket.sock"


def ensure_socket(path: Path) -> None:
    if not path.exists():
        fail(f"Socket not found: {path}")


def parse_event_line(line: str) -> tuple[str, str]:
    if ">>" not in line:
        return line, ""
    event_name, data = line.split(">>", 1)
    return event_name, data


def hypr_request(sock_path: Path, payload: str, timeout: float = 1.0) -> str:
    ensure_socket(sock_path)

    chunks: list[bytes] = []
    with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as client:
        client.settimeout(timeout)
        client.connect(str(sock_path))
        client.sendall(payload.encode("utf-8"))
        client.shutdown(socket.SHUT_WR)

        while True:
            chunk = client.recv(8192)
            if not chunk:
                break
            chunks.append(chunk)

    return b"".join(chunks).decode("utf-8", errors="replace")


def parse_workspacev2_data(data: str) -> tuple[int | None, str | None]:
    workspace_id, _, workspace_name = data.partition(",")

    try:
        parsed_id = int(workspace_id)
    except ValueError:
        parsed_id = None

    parsed_name = workspace_name or None
    return parsed_id, parsed_name


def get_active_workspace(instance_dir: Path, target_id: int | None) -> dict[str, object]:
    request_path = request_socket_path(instance_dir)

    for attempt in range(5):
        response = hypr_request(request_path, "j/activeworkspace")
        workspace = json.loads(response)

        if target_id is None or workspace.get("id") == target_id:
            return workspace

        time.sleep(0.03 * (attempt + 1))

    return workspace


def run_ags(workspace: dict[str, object]) -> None:
    env = os.environ.copy()
    env["HYPR_WORKSPACE_ID"] = str(workspace.get("id", ""))
    env["HYPR_WORKSPACE_NAME"] = str(workspace.get("name", ""))
    env["HYPR_WORKSPACE_WINDOWS"] = str(workspace.get("windows", "0"))
    env["HYPR_WORKSPACE_MONITOR"] = str(workspace.get("monitor", ""))
    env["HYPR_WORKSPACE_HAS_FULLSCREEN"] = "1" if workspace.get("hasfullscreen") else "0"

    try:
        subprocess.run(
            AGS_QUIT_COMMAND,
            check=False,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
        subprocess.run(AGS_COMMAND, check=False, env=env)
    except FileNotFoundError:
        fail(f"Command not found: {shlex.join(AGS_COMMAND)}")


def main() -> int:
    runtime_dir = resolve_runtime_dir()
    instance_dir = resolve_instance_dir(runtime_dir)
    sock_path = event_socket_path(instance_dir)
    ensure_socket(sock_path)

    try:
        with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as client:
            client.connect(str(sock_path))
            reader = client.makefile("r", encoding="utf-8", errors="replace")

            while True:
                line = reader.readline()
                if line == "":
                    return 0

                event_name, data = parse_event_line(line.rstrip("\n"))
                if event_name in WORKSPACE_EVENTS:
                    workspace_id, workspace_name = parse_workspacev2_data(data)
                    workspace = get_active_workspace(instance_dir, workspace_id)

                    if workspace_name and not workspace.get("name"):
                        workspace["name"] = workspace_name

                    run_ags(workspace)
    except KeyboardInterrupt:
        return 130


if __name__ == "__main__":
    raise SystemExit(main())