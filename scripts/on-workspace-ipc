#!/usr/bin/env python3
import os
import shlex
import socket
import subprocess
import sys
import time
from pathlib import Path
# https://wiki.hypr.land/IPC/

AGS_INSTANCE = "workspace-info-osd"
WORKSPACE_EVENT_DEBOUNCE_SECONDS = 0.12
AGS_QUIT_COMMAND = [
    "ags",
    "quit",
    "--instance",
    AGS_INSTANCE,
]
AGS_COMMAND = [
    "ags",
    "run",
    os.path.expanduser("~/.config/ags/window/onscreen-display/workspace-info.tsx"),
    "--gtk",
    "4",
]


def fail(message: str, exit_code: int = 1) -> "None":
    print(message, file=sys.stderr)
    raise SystemExit(exit_code)


def main() -> int:
    runtime_dir = os.environ.get("XDG_RUNTIME_DIR")
    if not runtime_dir:
        fail("XDG_RUNTIME_DIR is not set")

    runtime_path = Path(runtime_dir)
    if not runtime_path.exists():
        fail(f"Runtime directory does not exist: {runtime_path}")

    hypr_root = runtime_path / "hypr"
    if not hypr_root.is_dir():
        fail(f"Hyprland runtime directory not found: {hypr_root}")

    instance_dir: Path | None = None
    instance = os.environ.get("HYPRLAND_INSTANCE_SIGNATURE")
    if instance:
        candidate = hypr_root / instance
        if candidate.is_dir():
            instance_dir = candidate

    if instance_dir is None:
        candidates = sorted(path for path in hypr_root.iterdir() if path.is_dir())
        live_candidates = [
            path
            for path in candidates
            if (path / ".socket.sock").exists() and (path / ".socket2.sock").exists()
        ]

        if len(live_candidates) == 1:
            instance_dir = live_candidates[0]
        elif len(live_candidates) > 1:
            instance_dir = max(live_candidates, key=lambda path: path.stat().st_mtime)
        elif len(candidates) == 1:
            instance_dir = candidates[0]
        else:
            joined = ", ".join(path.name for path in candidates)
            fail(
                "Could not determine the active Hyprland runtime under "
                f"{hypr_root}. Found {len(candidates)} directories: {joined}"
            )

    sock_path = instance_dir / ".socket2.sock"
    if not sock_path.exists():
        fail(f"Socket not found: {sock_path}")

    last_workspace_event = 0.0
    current_workspace_id: str | None = None

    try:
        with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as client:
            client.connect(str(sock_path))
            reader = client.makefile("r", encoding="utf-8", errors="replace")

            while True:
                line = reader.readline()
                if line == "":
                    return 0

                raw_line = line.rstrip("\n")
                event_name = raw_line.split(">>", 1)[0]
                if event_name == "workspace":
                    payload = raw_line.split(">>", 1)[1] if ">>" in raw_line else ""
                    workspace_id = payload.strip()
                    if "," in workspace_id:
                        workspace_id = workspace_id.split(",", 1)[0].strip()

                    if workspace_id:
                        previous_workspace_id = current_workspace_id
                        current_workspace_id = workspace_id
                        os.environ["HYPRLAND_CURRENT_WORKSPACE_ID"] = current_workspace_id
                        if previous_workspace_id is None:
                            os.environ.pop("HYPRLAND_PREVIOUS_WORKSPACE_ID", None)
                        else:
                            os.environ["HYPRLAND_PREVIOUS_WORKSPACE_ID"] = previous_workspace_id

                    now = time.monotonic()
                    if now - last_workspace_event < WORKSPACE_EVENT_DEBOUNCE_SECONDS:
                        continue

                    last_workspace_event = now
                    try:
                        subprocess.run(
                            AGS_QUIT_COMMAND,
                            check=False,
                            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
                        )
                        # Launch AGS without waiting so the IPC event loop stays responsive.
                        subprocess.Popen(
                            AGS_COMMAND,
                            stdin=subprocess.DEVNULL,
                            stdout=subprocess.DEVNULL,
                            stderr=subprocess.DEVNULL,
                            env=os.environ.copy(),
                            start_new_session=True,
                            close_fds=True,
                        )
                    except FileNotFoundError:
                        fail(f"Command not found: {shlex.join(AGS_COMMAND)}")
    except KeyboardInterrupt:
        return 130


if __name__ == "__main__":
    raise SystemExit(main())